<Prefab>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>
        <Widget WidthSizePolicy="StretchToParent"
                HeightSizePolicy="StretchToParent"
                Sprite="BlankWhiteSquare_9"
                Color="#CC0A0E12">
          <Children>
            <Widget WidthSizePolicy="Fixed"
                    HeightSizePolicy="Fixed"
                    SuggestedWidth="1250"
                    SuggestedHeight="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Sprite="BlankWhiteSquare_9"
                    Color="#F2192430">
              <Children>
                <RichTextWidget WidthSizePolicy="CoverChildren"
                                HeightSizePolicy="CoverChildren"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                MarginTop="14"
                                Brush.FontSize="34"
                                Text="Spellbook" />

                <CharacterTableauWidget DataSource="{CurrentCharacter}"
                                        WidthSizePolicy="Fixed"
                                        HeightSizePolicy="Fixed"
                                        SuggestedWidth="400"
                                        SuggestedHeight="720"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        MarginRight="20"
                                        BannerCodeText="@BannerCodeText"
                                        BodyProperties="@BodyProperties"
                                        CharStringId="@CharStringId"
                                        EquipmentCode="@EquipmentCode"
                                        IsFemale="@IsFemale"
                                        MountCreationKey="@MountCreationKey"
                                        Race="@Race"
                                        StanceIndex="@StanceIndex"
                                        ArmorColor1="@ArmorColor1"
                                        ArmorColor2="@ArmorColor2"
                                        IsEnabled="false"
                                        DoNotUseCustomScale="true" />

                <Widget WidthSizePolicy="Fixed"
                        HeightSizePolicy="Fixed"
                        SuggestedWidth="760"
                        SuggestedHeight="700"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        MarginLeft="20">
                  <Children>
                    <ListPanel WidthSizePolicy="CoverChildren"
                               HeightSizePolicy="CoverChildren"
                               StackLayout.LayoutMethod="HorizontalLeftToRight"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top">
                      <Children>
                        <ButtonWidget WidthSizePolicy="Fixed"
                                      HeightSizePolicy="Fixed"
                                      SuggestedWidth="34"
                                      SuggestedHeight="34"
                                      Command.Click="ExecuteSelectPreviousHero"
                                      Sprite="BlankWhiteSquare_9"
                                      Color="#FF38536B">
                          <Children>
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Brush.FontSize="18"
                                            Text="&lt;" />
                          </Children>
                        </ButtonWidget>
                        <RichTextWidget WidthSizePolicy="CoverChildren"
                                        HeightSizePolicy="CoverChildren"
                                        MarginLeft="10"
                                        MarginRight="10"
                                        VerticalAlignment="Center"
                                        Brush.FontSize="24"
                                        Text="@HeroName" />
                        <ButtonWidget WidthSizePolicy="Fixed"
                                      HeightSizePolicy="Fixed"
                                      SuggestedWidth="34"
                                      SuggestedHeight="34"
                                      Command.Click="ExecuteSelectNextHero"
                                      Sprite="BlankWhiteSquare_9"
                                      Color="#FF38536B">
                          <Children>
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Brush.FontSize="18"
                                            Text="&gt;" />
                          </Children>
                        </ButtonWidget>
                      </Children>
                    </ListPanel>

                    <RichTextWidget WidthSizePolicy="CoverChildren"
                                    HeightSizePolicy="CoverChildren"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    MarginTop="46"
                                    Brush.FontSize="20"
                                    Text="@ClassName" />
                    <RichTextWidget WidthSizePolicy="CoverChildren"
                                    HeightSizePolicy="CoverChildren"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    MarginTop="74"
                                    Brush.FontSize="18"
                                    Text="@ManaText" />
                    <RichTextWidget WidthSizePolicy="CoverChildren"
                                    HeightSizePolicy="CoverChildren"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    MarginTop="100"
                                    Brush.FontSize="18"
                                    Text="@RegenText" />

                    <ListPanel DataSource="{Stats}"
                               WidthSizePolicy="Fixed"
                               HeightSizePolicy="Fixed"
                               SuggestedWidth="360"
                               SuggestedHeight="140"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               MarginTop="138"
                               StackLayout.LayoutMethod="VerticalBottomToTop">
                      <ItemTemplate>
                        <ListPanel WidthSizePolicy="StretchToParent"
                                   HeightSizePolicy="Fixed"
                                   SuggestedHeight="24"
                                   StackLayout.LayoutMethod="HorizontalLeftToRight">
                          <Children>
                            <RichTextWidget WidthSizePolicy="Fixed"
                                            HeightSizePolicy="CoverChildren"
                                            SuggestedWidth="170"
                                            Brush.FontSize="15"
                                            Text="@Label" />
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            Brush.FontSize="15"
                                            Text="@Value" />
                          </Children>
                        </ListPanel>
                      </ItemTemplate>
                    </ListPanel>

                    <RichTextWidget WidthSizePolicy="CoverChildren"
                                    HeightSizePolicy="CoverChildren"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    MarginTop="296"
                                    Brush.FontSize="22"
                                    Text="Selected Battle Spells" />

                    <ListPanel DataSource="{Spells}"
                               WidthSizePolicy="StretchToParent"
                               HeightSizePolicy="Fixed"
                               SuggestedHeight="350"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               MarginTop="332"
                               StackLayout.LayoutMethod="VerticalBottomToTop">
                      <ItemTemplate>
                        <ButtonWidget WidthSizePolicy="StretchToParent"
                                      HeightSizePolicy="Fixed"
                                      SuggestedHeight="70"
                                      Command.Click="ExecuteToggleSelected"
                                      Sprite="BlankWhiteSquare_9"
                                      Color="#FF203040">
                          <Children>
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            MarginLeft="12"
                                            MarginTop="8"
                                            Brush.FontSize="18"
                                            Text="@Name" />
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            MarginLeft="12"
                                            MarginTop="34"
                                            Brush.FontSize="14"
                                            Text="@Description" />
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            MarginRight="12"
                                            MarginTop="8"
                                            Brush.FontSize="14"
                                            Text="@ManaCostText" />
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            MarginRight="12"
                                            MarginTop="28"
                                            Brush.FontSize="14"
                                            Text="@CooldownText" />
                            <RichTextWidget WidthSizePolicy="CoverChildren"
                                            HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            MarginRight="12"
                                            MarginTop="46"
                                            Brush.FontSize="12"
                                            Text="@CastText" />
                          </Children>
                        </ButtonWidget>
                      </ItemTemplate>
                    </ListPanel>

                    <ButtonWidget WidthSizePolicy="Fixed"
                                  HeightSizePolicy="Fixed"
                                  SuggestedWidth="180"
                                  SuggestedHeight="34"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  MarginBottom="10"
                                  Command.Click="ExecuteClose"
                                  Sprite="BlankWhiteSquare_9"
                                  Color="#FF38536B">
                      <Children>
                        <RichTextWidget WidthSizePolicy="CoverChildren"
                                        HeightSizePolicy="CoverChildren"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Brush.FontSize="18"
                                        Text="Done" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </Widget>
              </Children>
            </Widget>
          </Children>
        </Widget>
      </Children>
    </Widget>
  </Window>
</Prefab>
